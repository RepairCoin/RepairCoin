# Frontend (Next.js) Environment Variables
# Copy to `.env` (or `.env.local`) and fill in your own values.
# Everything prefixed with NEXT_PUBLIC_ is exposed to the browser —
# NEVER put secret keys here.

# ---------------------------------------------------------------------------
# Blockchain (Base Sepolia testnet)
# ---------------------------------------------------------------------------
# RCN Token (Utility Token)
NEXT_PUBLIC_RCN_CONTRACT_ADDRESS=0xBFE793d78B6B83859b528F191bd6F2b8555D951C
NEXT_PUBLIC_RCN_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# RCG Token (Governance Token)
NEXT_PUBLIC_RCG_CONTRACT_ADDRESS=0xdaFCC0552d976339cA28EF2e84ca1c6561379c9D
NEXT_PUBLIC_RCG_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# Legacy support (single token/client id)
NEXT_PUBLIC_CONTRACT_ADDRESS=0xBFE793d78B6B83859b528F191bd6F2b8555D951C
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# Network
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_NETWORK=base-sepolia

# ---------------------------------------------------------------------------
# URLs
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# WebSocket URL for real-time notifications
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ---------------------------------------------------------------------------
# App info
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=RepairCoin
NEXT_PUBLIC_APP_DESCRIPTION=Loyalty tokens for repair shops

# Admin wallet addresses (comma-separated, lowercase)
NEXT_PUBLIC_ADMIN_ADDRESSES=0xyouradminwallet

# ---------------------------------------------------------------------------
# Payments — Stripe (publishable key only; safe for client)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ---------------------------------------------------------------------------
# Maps / routing
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key
# Map default center/zoom (optional)
NEXT_PUBLIC_MAP_DEFAULT_LAT=14.5995
NEXT_PUBLIC_MAP_DEFAULT_LNG=120.9842
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=12

# ---------------------------------------------------------------------------
# Security / feature flags
# ---------------------------------------------------------------------------
# Google reCAPTCHA v3 site key (public)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
# Toggle the ads dashboard UI: true | false
NEXT_PUBLIC_ADS_DASHBOARD_ENABLED=false
