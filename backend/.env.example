# Backend (Express) Environment Variables
# Copy to `.env` and fill in real values. This file documents every variable
# the backend reads. Keep all real secrets out of version control.

# ===========================================================================
# Core
# ===========================================================================
NODE_ENV=development
PORT=4000
# Frontend origin (used for links/redirects and CORS)
FRONTEND_URL=http://localhost:3001
# Public base URLs for this API (used in webhooks/emails/assets)
API_BASE_URL=http://localhost:4000
API_PUBLIC_URL=http://localhost:4000
PUBLIC_ASSET_URL=http://localhost:4000

# ===========================================================================
# Auth / JWT
# ===========================================================================
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
# Cookie settings
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ===========================================================================
# Database (PostgreSQL)
# ===========================================================================
# Either provide DATABASE_URL OR the discrete DB_* values below.
# DATABASE_URL=postgresql://user:password@host:25060/defaultdb?sslmode=require
DB_HOST=localhost
DB_PORT=5432
DB_USER=repaircoin
DB_PASSWORD=repaircoin123
DB_NAME=repaircoin
DB_SSL=false
# Optional CA certificate (PEM) for managed DBs
DB_CA_CERT=
# Pool / timeout tuning (optional)
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=30000
# Skip DB connectivity checks on startup (testing only): true | false
SKIP_DB_CONNECTION_TESTS=false

# ===========================================================================
# Blockchain (Base Sepolia testnet)
# ===========================================================================
NETWORK=base-sepolia
# Admin wallet private key (NO 0x prefix). Signs mint/transfer transactions.
PRIVATE_KEY=your_admin_wallet_private_key

# RCN Token (Utility Token)
RCN_CONTRACT_ADDRESS=0xBFE793d78B6B83859b528F191bd6F2b8555D951C
RCN_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
RCN_THIRDWEB_SECRET_KEY=your_thirdweb_secret_key
RCN_BURN_ADDRESS=0x000000000000000000000000000000000000dEaD

# RCG Token (Governance Token)
RCG_CONTRACT_ADDRESS=0xdaFCC0552d976339cA28EF2e84ca1c6561379c9D
RCG_THIRDWEB_CLIENT_ID=your_thirdweb_client_id
RCG_THIRDWEB_SECRET_KEY=your_thirdweb_secret_key

# Legacy Thirdweb (backward compatibility)
THIRDWEB_CLIENT_ID=your_thirdweb_client_id
THIRDWEB_SECRET_KEY=your_thirdweb_secret_key
REPAIRCOIN_CONTRACT_ADDRESS=0xBFE793d78B6B83859b528F191bd6F2b8555D951C
REPAIRCOIN_TOKEN_ADDRESS=0xBFE793d78B6B83859b528F191bd6F2b8555D951C

# Custom RPC endpoints (optional; defaults to public Base Sepolia RPC)
RPC_ENDPOINT=
RPC_BACKUP_ENDPOINT=

# On-chain role wallets (optional)
TREASURY_ADDRESS=
SHOP_MANAGER_ADDRESS=
TIER_MANAGER_ADDRESS=

# Toggle real on-chain minting (false = DB-only): true | false
ENABLE_BLOCKCHAIN_MINTING=false

# ===========================================================================
# Admin configuration
# ===========================================================================
# Comma-separated admin wallet addresses (lowercase)
ADMIN_ADDRESSES=0xyouradminwallet
ADMIN_NAME=Admin
SUPER_ADMIN_ADDRESS=0xyoursuperadminwallet
DEFAULT_ADMIN_EMAIL=admin@repaircoin.ai
ADMIN_NOTIFICATION_EMAIL=admin@repaircoin.ai
ADMIN_ALERT_EMAILS=admin@repaircoin.ai
# Skip startup role-conflict validation: true | false
ADMIN_SKIP_CONFLICT_CHECK=false

# ===========================================================================
# Payments — Stripe
# ===========================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
# Legacy single-plan price (retained as fallback for un-migrated subscribers)
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_subscription_price_id
# Subscription tier prices
STRIPE_PRICE_STARTER=price_your_starter_tier_price_id
STRIPE_PRICE_GROWTH=price_your_growth_tier_price_id
STRIPE_PRICE_BUSINESS=price_your_business_tier_price_id
# Agency Program add-on base plan ($999/mo)
STRIPE_PRICE_AGENCY_BASE=price_your_agency_base_price_id
# Agency Program per-extra-client price ($50/mo, quantity = clients beyond client_limit)
STRIPE_PRICE_AGENCY_EXTRA_CLIENT=price_your_agency_extra_client_price_id
# Stripe Connect — shop payout onboarding via OAuth. Get the client id (ca_...) from
# Stripe Dashboard → Settings → Connect → Integration, and register the redirect URI there.
# Required for POST /api/shops/connect/onboarding-link (else it 500s "not configured").
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_oauth_client_id
# Optional — defaults to {API_BASE_URL}/api/shops/connect/oauth/callback
# STRIPE_CONNECT_REDIRECT_URI=https://api.yourdomain.com/api/shops/connect/oauth/callback

# ===========================================================================
# Email
# ===========================================================================
# Resend — the sender for all transactional email. The sending domain must be
# verified on the Resend account for these to deliver.
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@repaircoin.ai
RESEND_FROM_NAME=RepairCoin
# SendGrid — fallback for bulk marketing campaigns only (CampaignEmailService)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@repaircoin.ai
SENDGRID_FROM_NAME=RepairCoin
SUPPORT_EMAIL=support@repaircoin.ai

# ===========================================================================
# Storage — DigitalOcean Spaces (S3-compatible)
# ===========================================================================
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret
DO_SPACES_BUCKET=your_bucket_name
DO_SPACES_REGION=sfo3
DO_SPACES_CDN_ENDPOINT=https://your_bucket.sfo3.cdn.digitaloceanspaces.com

# ===========================================================================
# Google integrations
# ===========================================================================
# Google Calendar OAuth
GOOGLE_CALENDAR_CLIENT_ID=your_google_calendar_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_calendar_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:4000/api/shops/calendar/callback/google
GOOGLE_CALENDAR_ENCRYPTION_KEY=your_32_byte_hex_encryption_key
# Gmail OAuth (campaign sending)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:4000/api/admin/gmail/callback
GMAIL_ENCRYPTION_KEY=your_32_byte_hex_encryption_key
# Firebase (push / messaging)
FIREBASE_PROJECT_ID=your_firebase_project_id

# ===========================================================================
# Web Push (VAPID) — see https://github.com/web-push-libs/web-push
# ===========================================================================
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@repaircoin.ai

# ===========================================================================
# WhatsApp (Meta Cloud API)
# ===========================================================================
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_API_VERSION=v21.0

# ===========================================================================
# Meta / Ads platform integration
# ===========================================================================
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
ADS_BILLING_STRIPE_ENABLED=false
ADS_LEAD_TRANSPORT_ENABLED=false
ADS_INBOUND_WEBHOOK_TOKEN=your_inbound_webhook_token
# AI-initiated first contact (Part B): when true + a campaign is in 'auto' outreach mode, the AI
# sends the first message to a freshly captured, contactable lead. Default off.
ADS_AI_INITIATE_ENABLED=false
# Messenger channel: route inbound Facebook Messenger messages into the AI loop + send AI replies via
# the Send API (uses the connected Page token). Needs `pages_messaging` App Review to reach real users
# (works for app-role test users before that). Default off.
ADS_MESSENGER_ENABLED=false
# SMS channel for the ads lead loop (send AI replies + receive lead texts via Twilio). Requires the
# shared Twilio config below AND ADS_LEAD_TRANSPORT_ENABLED. Default off.
ADS_SMS_ENABLED=false

# ===========================================================================
# Twilio SMS (shared across ads, notifications, marketing)
# ===========================================================================
# Master gate for ALL platform SMS. Off by default. On a Twilio TRIAL account you can only text
# verified numbers; real customers + US marketing need a paid account + A2P 10DLC registration.
TWILIO_SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# The SMS-capable Twilio number to send from (E.164, e.g. +15551234567). Used as the shared
# fallback FROM number until a shop is provisioned its own dedicated number (shop_sms_numbers, D2).
TWILIO_SMS_FROM=+15551234567

# AI Auto-Replies over SMS for REGULAR customers (Business-tier feature; distinct from the ads
# lead SMS flag ADS_SMS_ENABLED). When on, an AI reply on a channel='sms' conversation is relayed
# back to the customer over SMS. Requires the shared Twilio config above. Default off — the SMS
# inbound path that creates such conversations is still being built (Phase 1).
ENABLE_CUSTOMER_SMS=false

# AI Auto-Replies over WhatsApp for REGULAR customers (Business-tier). When on, an AI reply on a
# channel='whatsapp' conversation is relayed back over WhatsApp (via the WHATSAPP_* config below).
# Reactive replies stay inside WhatsApp's 24-hour window (no template needed). Default off — the
# WhatsApp inbound webhook + per-shop WhatsApp sender are still being built (Phase 2).
ENABLE_CUSTOMER_WHATSAPP=false
# Until per-shop WhatsApp senders are provisioned, inbound WhatsApp on the single platform number
# (WHATSAPP_PHONE_NUMBER_ID) is attributed to this shop. Leave empty to skip WhatsApp inbound routing.
WHATSAPP_DEFAULT_SHOP_ID=
# Estimated per-message CARRIER cost (cents) recorded in the customer_messaging_costs ledger (D5) for
# each off-channel AI reply. Rough defaults; calibrate to your Twilio/WhatsApp billing.
SMS_CARRIER_COST_CENTS=0.79
WHATSAPP_CARRIER_COST_CENTS=0

# Enforce opt-IN consent (D6/TCPA) before sending an automated customer SMS/WhatsApp reply. Consent is
# always RECORDED on inbound (customer-initiated = implied opt-in); this flag only turns on ENFORCEMENT
# (block sends without a granted consent row). Default off — flip ON only after legal sign-off + a
# consent-capture flow, and audit affected shops first (fails CLOSED when on).
ENFORCE_MESSAGING_CONSENT=false

# AI Usage Overage (T3.2): master switch. When on, a shop that opts in (ai_shop_settings.ai_overage_enabled)
# keeps full-power AI past its monthly allowance instead of degrading to the lighter model (billed
# "Usage x3" — metering/charging are later slices). Default off — inert until ready.
ENABLE_AI_OVERAGE=false
# Bill-shock guardrail: per-shop monthly cap on the BILLABLE overage (dollars the shop would be
# invoiced, = overage cost x3). Once reached, overage stops lifting the model (reverts to the lighter
# model) so a runaway session can't create a surprise invoice. 0 = unlimited. Default 100.
AI_OVERAGE_MONTHLY_CAP_USD=100
# Require a payment method on file before a shop can ENABLE overage (a billable feature). Default on;
# set =false to bypass for behavior-testing on staging where shops may have no card.
AI_OVERAGE_REQUIRE_CARD=true
# Slice 3 — master switch for actually CHARGING accrued overage via Stripe (direct invoice to the
# shop's existing customer, like ads billing). Default off (accrual + metering run regardless). Flip on
# only after the Usage x3 terms are signed off + live Stripe keys are set.
AI_OVERAGE_STRIPE_ENABLED=false
# AI Campaigns (Advanced) / auto-message automation — Business-tier gate (T3.x pricing). The shop
# Auto-Messages engine (scheduled/triggered/win-back messaging) is currently open to ALL tiers; this flag
# enforces it as Business-only. Default OFF so the gate ships dark (no behavior change) — flip to true to
# enforce once shops are notified. Drives BOTH the route guard and the frontend feature-access map.
ENFORCE_CAMPAIGN_AUTOMATION_TIER=false

# ===========================================================================
# AI providers (optional features)
# ===========================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key
# Central Claude model config (backend/src/config/aiModels.ts). Optional — omit to use the defaults.
#   AI_MODEL_SMART  — reasoning/tool-use tier: the unified assistant, insights, marketing, customer chat.
#                     Default claude-sonnet-4-6. Set to claude-sonnet-5 to upgrade the whole smart tier.
#   AI_MODEL_CHEAP  — light tasks + spend-cap fallback (default claude-haiku-4-5-20251001).
#   AI_MODEL_<FEATURE> — optional per-feature override via modelFor() (none wired today; available for a
#                        one-off test, e.g. Fable 5 on a single future autonomous-agent feature).
# AI_MODEL_SMART=claude-sonnet-5
# AI_MODEL_CHEAP=claude-haiku-4-5-20251001
OPENAI_API_KEY=your_openai_api_key
STABILITY_API_KEY=your_stability_api_key

# ===========================================================================
# Captcha (Google reCAPTCHA v3)
# ===========================================================================
ENABLE_CAPTCHA=false
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_MIN_SCORE=0.5

# ===========================================================================
# Webhooks / integrations
# ===========================================================================
FIXFLOW_WEBHOOK_SECRET=your_fixflow_webhook_secret
# Deep link scheme used in customer-facing mobile links
MOBILE_DEEP_LINK_SCHEME=repaircoin

# ===========================================================================
# Feature flags
# ===========================================================================
ENABLE_SWAGGER=true
ENABLE_TEST_ENDPOINTS=false
CORS_DISABLED=false
AUTO_DETECTION_ENABLED=false
AI_FOLLOWUP_ENABLED=false
SUSPENSION_LIFT_ENABLED=false
LOW_STOCK_ALERTS_ENABLED=false
INSIGHTS_ANOMALY_DETECTION_ENABLED=false
# Daily digest send hour (UTC, 0-23)
DAILY_DIGEST_HOUR_UTC=8

# ===========================================================================
# Misc
# ===========================================================================
# Directory for the in-app help corpus (optional)
HELP_CORPUS_DIR=
