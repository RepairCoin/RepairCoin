{
  "cli": {
    "version": ">= 16.18.1",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "env": {
        "NODE_VERSION": "20"
      },
      "android": {
        "prebuildCommand": "bash ./eas-build-pre-install.sh"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "env": {
          "EX_UPDATES_NATIVE_DEBUG": "1"
        },
        "gradleCommand": ":app:assembleRelease",
        "withoutCredentials": false
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_NO_CAPABILITY_SYNC": "1",
        "EXPO_PUBLIC_API_URL": "https://api-staging.repaircoin.ai/api",
        "EXPO_PUBLIC_RCN_CONTRACT_ADDRESS": "0xBFE793d78B6B83859b528F191bd6F2b8555D951C",
