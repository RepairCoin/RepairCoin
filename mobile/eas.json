{
  "cli": {
    "version": ">= 16.18.1",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "env": {
        "NODE_VERSION": "20"
      }
    },
    "tester": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "env": {
          "EX_UPDATES_NATIVE_DEBUG": "1"
        },
        "gradleCommand": ":app:assembleRelease",
        "withoutCredentials": false
      },
      "env": {
        "APP_ENV": "staging",
        "EXPO_NO_CAPABILITY_SYNC": "1"
      },
      "ios": {
        "simulator": false
      },
      "channel": "tester"
    },
    "preview": {
      "extends": "base",
      "distribution": "store",
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "ios": {
        "simulator": false,
        "autoIncrement": true
      },
      "env": {
        "APP_ENV": "staging"
      },
      "channel": "preview"
    },
    "production": {
      "extends": "base",
      "distribution": "store",
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "ios": {
        "simulator": false,
        "autoIncrement": true
      },
      "env": {
        "APP_ENV": "production"
      },
      "channel": "production"
    }
  },
  "submit": {
    "preview": {
      "android": {
        "track": "internal",
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "sanggoyodk8@gmail.com"
      }
    },
    "production": {
      "android": {
        "track": "production",
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "sanggoyodk8@gmail.com",
        "ascAppId": "6760699735"
      }
    }
  }
}
