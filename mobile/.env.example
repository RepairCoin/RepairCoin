# Mobile (Expo) Environment Variables
# Copy to `.env.local` and fill in your own values.
# Anything prefixed with EXPO_PUBLIC_ is bundled into the app and visible to
# clients — NEVER put secret keys here.

# Build/runtime environment: local | staging | production
APP_ENV=local

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
# Backend base URL (must include /api).
# Android emulator: use http://10.0.2.2:4000/api (host alias, NOT localhost).
# Physical device: use your machine's LAN IP, e.g. http://192.168.1.5:4000/api
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000/api

# Demo login button: set to "disable" to hide it
EXPO_PUBLIC_DEMO=disable

# ---------------------------------------------------------------------------
# Blockchain (Base Sepolia testnet)
# ---------------------------------------------------------------------------
# RCN Token (Utility Token)
EXPO_PUBLIC_RCN_CONTRACT_ADDRESS=0xBFE793d78B6B83859b528F191bd6F2b8555D951C
EXPO_PUBLIC_RCN_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# RCG Token (Governance Token)
EXPO_PUBLIC_RCG_CONTRACT_ADDRESS=0xdaFCC0552d976339cA28EF2e84ca1c6561379c9D
EXPO_PUBLIC_RCG_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# Legacy support (single token/client id)
EXPO_PUBLIC_CONTRACT_ADDRESS=0xBFE793d78B6B83859b528F191bd6F2b8555D951C
EXPO_PUBLIC_THIRDWEB_CLIENT_ID=your_thirdweb_client_id

# Network
EXPO_PUBLIC_CHAIN_ID=84532
EXPO_PUBLIC_NETWORK=base-sepolia

# ---------------------------------------------------------------------------
# App info
# ---------------------------------------------------------------------------
EXPO_PUBLIC_APP_NAME=RepairCoin
EXPO_PUBLIC_APP_DESCRIPTION=Loyalty tokens for repair shops

# Admin wallet addresses (comma-separated, lowercase)
EXPO_PUBLIC_ADMIN_ADDRESSES=0xyouradminwallet

# ---------------------------------------------------------------------------
# Payments — Stripe (publishable key only; safe for client)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ---------------------------------------------------------------------------
# Maps / routing
# ---------------------------------------------------------------------------
EXPO_PUBLIC_OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token
